# Working notes / progress docs are local-only — only README.md is tracked
*.md
!README.md

# Secrets / credentials
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
secrets.*
credentials.*
*.token

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Data pulls & run outputs (regenerated, never committed)
data/*
out/*
!data/.gitkeep
!out/.gitkeep

# Large local datasets — never publish (downloaded dumps, archives)
Historical Data/
*.zip

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp

# Logs & temp
*.log
tmp/
temp/
