# Copy this file to .env and fill in your keys. .env is git-ignored.

# Together API key — required for the persona LLM calls.
TOGETHER_API_KEY=your_together_key_here

# Steam Web API key — optional, only for profile enrichment in the full run.
STEAM_API_KEY=

# Path to the reused Senti-Minted checkout (defaults to ~/Senti-Minted if unset).
# SENTI_MINTED_PATH=
